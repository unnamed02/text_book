.page-container {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.info-card {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.info-row {
  margin-top: 8rpx;
  font-size: 26rpx;
}

.stats-row {
  display: flex;
  gap: 32rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #333;
}

.selected-item {
  font-size: 28rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.selected-item:last-child {
  border-bottom: none;
}

.table-header {
  display: flex;
  background: #fafafa;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
}

.table-row {
  display: flex;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  align-items: center;
  background: #fff;
}

.row-active {
  background: #f6ffed;
}

.row-disabled {
  opacity: 0.6;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  width: 80%;
  max-width: 560rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-btns {
  display: flex;
  gap: 16rpx;
}

.th, .td {
  padding: 0 8rpx;
}

.th-name, .td-name {
  flex: 3;
}

.th-course, .td-course {
  flex: 2;
}

.th-price, .td-price {
  flex: 1;
  text-align: center;
}

.th-action, .td-action {
  flex: 1;
  text-align: center;
}

.td-title {
  font-size: 28rpx;
  color: #333;
}

.td-sub {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 48rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}
