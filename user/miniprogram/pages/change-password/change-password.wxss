.page-container {
  min-height: 100vh;
  background: #f0f2f5;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 48rpx;
}

.alert-box {
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.alert-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #d48806;
  margin-bottom: 8rpx;
}

.alert-desc {
  font-size: 26rpx;
  color: #d48806;
}
