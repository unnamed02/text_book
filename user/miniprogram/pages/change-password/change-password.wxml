<view class="page-container">
  <view class="card" style="max-width: 640rpx; width: 100%;">
    <view class="page-title" style="text-align: center; margin-bottom: 32rpx;">修改密码</view>

    <view class="alert-box">
      <view class="alert-title">首次登录需要修改初始密码</view>
      <view class="alert-desc">初始密码为 123456，为了账户安全，请设置新密码。</view>
    </view>

    <view class="form-item">
      <text class="label">旧密码</text>
      <input class="input" placeholder="请输入旧密码" password value="{{oldPassword}}" bindinput="onOldPasswordInput" />
    </view>

    <view class="form-item">
      <text class="label">新密码</text>
      <input class="input" placeholder="请设置新密码（至少6位）" password value="{{newPassword}}" bindinput="onNewPasswordInput" />
    </view>

    <view class="form-item">
      <text class="label">确认新密码</text>
      <input class="input" placeholder="请再次输入新密码" password value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
    </view>

    <button class="btn-primary" bindtap="handleSubmit" loading="{{loading}}">确认修改</button>
  </view>
</view>

<modal title="修改密码失败" hidden="{{!modalVisible}}" bindconfirm="onModalClose" confirmText="确定" showCancel="{{false}}">
  <view>{{modalMsg}}</view>
</modal>
