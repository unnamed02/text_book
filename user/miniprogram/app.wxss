page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #f5f5f5;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.btn-primary {
  background: #1677ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  background: #91caff;
  color: #fff;
}

.btn-default {
  background: #fff;
  color: #595959;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
}

.btn-default::after {
  border: none;
}

.btn-disabled {
  background: #f5f5f5;
  color: #bfbfbf;
  border-radius: 8rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
}

.btn-disabled::after {
  border: none;
}

.input {
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  background: #fff;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.text-secondary {
  font-size: 24rpx;
  color: #999;
}

.text-danger {
  color: #ff4d4f;
}

.text-success {
  color: #52c41a;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}
